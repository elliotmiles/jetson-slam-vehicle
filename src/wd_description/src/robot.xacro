        <parent link="base_link"/>
        <child link="driver_left_link"/>
        <origin xyz="0.04576 0.03548 0.018"/>
    </joint>

    <!-- ========= MOTOR DRIVER R ========= -->

    <link name="driver_right_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/driver_right_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/driver_right_link.stl" scale="0.001 0.001 0.001"/>
