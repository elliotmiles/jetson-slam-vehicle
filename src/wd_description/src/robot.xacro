        <child link="driver_right_link"/>
        <origin xyz="0.04576 -0.03548 0.018"/>
    </joint>


    <!-- ========= WHEEL L ========= -->

    <link name="wheel_left_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="blue"/>
