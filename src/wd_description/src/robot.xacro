    <!-- ========= LIDAR ========= -->

    <link name="lidar_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/lidar_link.stl" scale="0.001 0.001 0.001"/>
