        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/caster_fork_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey"/>
