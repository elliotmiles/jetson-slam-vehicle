        <!-- done -->
        <xacro:inertial_box mass="0.187" x="0.1" y="0.07" z="0.055">
            <origin xyz="0 0 0.0275" rpy="0 0 0"/>
        </xacro:inertial_box>  
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
