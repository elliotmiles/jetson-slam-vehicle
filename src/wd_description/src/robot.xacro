    <joint name="pcb_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pcb_link"/>
        <origin xyz="0.005 0 0.065"/>
    </joint>


    <!-- ========= MOTOR DRIVER L ========= -->

    <link name="driver_left_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/driver_left_link.stl" scale="0.001 0.001 0.001"/>
