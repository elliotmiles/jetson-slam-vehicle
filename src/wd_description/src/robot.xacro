<?xml version="1.0"?>
<robot name="wheely_dan" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro" />
    
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/>
    </material>

    <!-- ========= BASE ========= -->

    <link name="base_link">

    </link>

    <!-- ========= CHASSIS ========= -->

    <link name="chassis_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/chassis_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/chassis_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <xacro:inertial_box mass="m" x="x" y="y" z="z">
            <origin xyz="" rpy="0 0 0"/>
        </xacro:inertial_box>  
    </link>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="-0.035 0 0"/>
    </joint>  


    <!-- ========= JETSON ========= -->

    <link name="jetson_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/jetson_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/jetson_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <xacro:inertial_box mass="m" x="x" y="y" z="z">
            <origin xyz="" rpy="0 0 0"/>
        </xacro:inertial_box>        
    </link>

    <joint name="jetson_joint" type="fixed">
        <parent link="base_link"/>
        <child link="jetson_link"/>
        <origin xyz="0.12625 0 0.057"/>
    </joint>

    
    <!-- ========= BATTERY ========= -->

    <link name="battery_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/battery_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </material name="red"/>
        </visual>

        <collision>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/battery_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        </collision>

        <xacro:inertial_box mass="m" x="x" y="y" z="z">
            <origin xyz="" rpy="0 0 0"/>
        </xacro:inertial_box>  
    </link>

    <joint name="battery_joint" type="fixed">
        <parent link="base_link"/>
        <child link="battery_link"/>
        <origin xyz="0.163 0 0.011"/>
    </joint>

    <!-- ========= PCB ========= -->

    <link name="pcb_link">
        <visual>
        <geometry>
            <mesh filename="file:///home/logicbomb/Projects/SLAM/wheely-dan/src/wd_description/meshes/pcb_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="green"/>
